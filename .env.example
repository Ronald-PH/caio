# ─────────────────────────────────────────────────────
# CAIO — Environment Configuration
# Copy this file to .env and fill in your values.
# Lines starting with # are comments.
# ─────────────────────────────────────────────────────

# Flask secret key (change this to a random string in production!)
SECRET_KEY=change-me-to-a-random-string

# ── AI Providers ──────────────────────────────────────
# Ollama (local) — no API key needed, just run: ollama serve
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=llama3.2

# OpenAI — get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic Claude — get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Which provider to use by default: ollama | openai | claude
DEFAULT_PROVIDER=ollama

# ── Cost Rates ($/1K tokens) ──────────────────────────
# Adjust if OpenAI/Anthropic update their pricing
OPENAI_INPUT_RATE=0.005
OPENAI_OUTPUT_RATE=0.015
CLAUDE_INPUT_RATE=0.003
CLAUDE_OUTPUT_RATE=0.015
